# ============================================================
# FormFlow — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ----- Server -----------------------------------------------
NODE_ENV=development
PORT=3001

# Azure SQL connection string
# Format: Server=tcp:<server>.database.windows.net,1433;Database=<db>;User Id=<user>;Password=<pass>;Encrypt=true
DATABASE_URL=

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Stripe (server-side secret key — never expose to client)
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — get from `stripe listen` output or Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# ----- Client (Vite — must be prefixed with VITE_) ----------
# These values ARE bundled into the frontend JS — only put public keys here.
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
